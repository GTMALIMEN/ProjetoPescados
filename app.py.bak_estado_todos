def br_money(value) -> str:
    if value is None or pd.isna(value):
        return "N/A"
    return "R$ " + f"{float(value):,.2f}".replace(",", "X").replace(".", ",").replace("X", ".")


def br_num(value) -> str:
    if value is None or pd.isna(value):
        return "N/A"
    return f"{float(value):,.2f}".replace(",", "X").replace(".", ",").replace("X", ".")


def safe_metric(value, default="N/A"):
    if isinstance(value, pd.Series):
        value = value.sum()
    if isinstance(value, (pd.DataFrame, list, tuple, dict)):
        return default
    if value is None or pd.isna(value):
        return default
    if isinstance(value, float) and value.is_integer():
        return int(value)
    return value


def df_display(df: pd.DataFrame) -> pd.DataFrame:
    if df is None or not isinstance(df, pd.DataFrame):
        return pd.DataFrame()

    out = df.copy()

    # Evita erro/warning do Arrow quando uma coluna object mistura float + string.
    for col in out.columns:
        if out[col].dtype == "object":
            out[col] = out[col].where(pd.notna(out[col]), "N/A").astype(str)

    return out


def dataframe_or_warning(df, warning: str):
    if df is None:
        st.warning(warning)
        return
    if isinstance(df, dict):
        if not df:
            st.warning(warning)
        else:
            st.dataframe(pd.DataFrame([df]), use_container_width=True)
        return
    if not isinstance(df, pd.DataFrame):
        st.write(df)
        return
    if df.empty:
        st.warning(warning)
    else:
        st.dataframe(df_display(df), use_container_width=True)




