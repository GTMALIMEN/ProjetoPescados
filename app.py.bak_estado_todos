            file_name=f"previsao_mercado_{periodo_prev.lower().replace(' ', '_')}_bases.xlsx",
            mime="application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
        )

    except Exception as e:
        st.error("Erro ao carregar Análise Previsão de Mercado.")
        st.exception(e)


