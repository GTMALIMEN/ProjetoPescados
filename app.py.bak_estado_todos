with aba_previsao:
    st.subheader("📈 Análise Previsão de Mercado")
    st.info("Estrutura V2.1: filtro de período, dólar separado, tabelas consolidadas, CEAGESP, compra, prévia vendedores e exportação. Prophet fica para etapa posterior.")

    try:
        st.markdown("### Filtro de período")
        c_periodo, c_inicio, c_fim = st.columns([1.2, 1, 1])
        with c_periodo:
            periodo_prev = st.selectbox(
                "Período",
                ["Últimos 12 meses", "Últimos 3 meses", "Últimos 6 meses", "Últimos 24 meses", "Ano atual", "Tudo", "Personalizado"],
                index=0,
                key="prev_periodo",
            )

        data_inicio_auto, data_fim_auto = _date_range_from_period(periodo_prev)
        with c_inicio:
            data_inicio_prev = st.date_input(
                "Data início",
                value=data_inicio_auto,
                disabled=periodo_prev != "Personalizado",
                key="prev_data_inicio",
            ) if periodo_prev == "Personalizado" else data_inicio_auto
        with c_fim:
            data_fim_prev = st.date_input(
                "Data fim",
                value=data_fim_auto,
                disabled=periodo_prev != "Personalizado",
                key="prev_data_fim",
            ) if periodo_prev == "Personalizado" else data_fim_auto

        indicadores = listar_indicadores_disponiveis()
        indicadores_dolar = [
            i for i in indicadores
            if any(t in str(i).lower() for t in ["dólar", "dolar", "usd", "cambio", "câmbio", "ptax"])
        ]

        st.markdown("### Dólar / Câmbio")
        if indicadores_dolar:
            indicador_dolar = st.selectbox("Indicador de dólar/câmbio", indicadores_dolar, key="prev_indicador_dolar")
            df_dolar = _filter_df_by_period(carregar_radar_economico_ultimo_ano(indicador_dolar), data_inicio_prev, data_fim_prev)
            resumo_dolar = resumo_radar_economico_ultimo_ano(indicador_dolar)
            c1, c2, c3 = st.columns(3)
            c1.metric("Último valor", br_num(resumo_dolar.get("ultimo_valor")))
            c2.metric("Última data", str(resumo_dolar.get("ultima_data")))
            c3.metric("Tendência", resumo_dolar.get("tendencia"))
            if not df_dolar.empty:
                fig_dolar = px.line(df_dolar, x="data", y="valor", title=f"{indicador_dolar} — período selecionado")
                st.plotly_chart(fig_dolar, use_container_width=True)
        else:
            st.warning("Nenhum indicador de dólar/câmbio encontrado nas séries carregadas.")

        st.markdown("### Radar econômico — demais indicadores")
        indicadores_gerais = [i for i in indicadores if i not in indicadores_dolar]
        indicador = st.selectbox("Indicador econômico", indicadores_gerais, key="prev_indicador") if indicadores_gerais else None
        if indicador:
            df_econ = _filter_df_by_period(carregar_radar_economico_ultimo_ano(indicador), data_inicio_prev, data_fim_prev)
            resumo_econ = resumo_radar_economico_ultimo_ano(indicador)
            c1, c2, c3 = st.columns(3)
            c1.metric("Último valor", br_num(resumo_econ.get("ultimo_valor")))
            c2.metric("Última data", str(resumo_econ.get("ultima_data")))
            c3.metric("Tendência", resumo_econ.get("tendencia"))
            if not df_econ.empty:
                fig = px.line(df_econ, x="data", y="valor", title=f"{indicador} — período selecionado")
                st.plotly_chart(fig, use_container_width=True)

        st.markdown("### Proteínas e grãos consolidados")
        produtos = listar_produtos_setoriais(uf="MG")
        produtos_default = [p for p in ["Tilápia", "Salmão", "Camarão", "Milho", "Soja"] if p in produtos] or produtos[:min(5, len(produtos))]
        produtos_sel = st.multiselect("Produtos para comparar", produtos, default=produtos_default, key="prev_produtos")
        modo = st.selectbox("Modo de comparação", ["Preço original", "Base 100", "Variação mensal %", "Variação acumulada %"], key="prev_modo")
        df_pg = _filter_df_by_period(carregar_proteinas_graos_unificado(produtos=produtos_sel), data_inicio_prev, data_fim_prev, possible_cols=["mes", "data"])
        if df_pg.empty:
            st.warning("Sem dados de proteínas/grãos.")
        else:
            y_col = {
                "Preço original": "valor_medio",
                "Base 100": "indice_base100",
                "Variação mensal %": "variacao_mensal_pct",
                "Variação acumulada %": "variacao_acumulada_pct",
            }[modo]
            fig_pg = px.line(df_pg, x="mes", y=y_col, color="produto", line_dash="categoria", title=f"Proteínas e grãos — {modo} — período selecionado")
            st.plotly_chart(fig_pg, use_container_width=True)
            with st.expander("Ver base de proteínas e grãos"):
                dataframe_periodo(df_pg, "Sem dados.", data_inicio_prev, data_fim_prev)

        st.markdown("### Bases de mercado")
        tab_ceagesp, tab_compra, tab_vend = st.tabs(["CEAGESP Pescados", "Base de Compra", "Prévia Vendedores"])

        with tab_ceagesp:
            st.caption("CEAGESP ficou manual/controlado. Carregue com `python scripts/load_ceagesp_manual_file.py --arquivo \"data\\input\\ceagesp_manual.csv\"`. A tabela mantém histórico e evita duplicidade por produto/data/classificação/unidade.")
            dataframe_periodo(carregar_base_ceagesp_historico(), "Sem histórico CEAGESP carregado.", data_inicio_prev, data_fim_prev)

        with tab_compra:
            st.caption('Etapa 27: carregue histórico desde 2022 com `python scripts/load_compra_manual_file.py --arquivo "data\\\\input\\\\base_compra_manual.csv"`.')
            dataframe_or_warning(carregar_base_compra_resumo(), "Sem resumo de compra manual.")
            dataframe_periodo(carregar_base_compra_manual(), "Sem base de compra manual importada.", data_inicio_prev, data_fim_prev)

        with tab_vend:
            st.caption('Etapa 28: carregue a prévia com `python scripts/load_previa_vendedores_file.py --arquivo "data\\\\input\\\\previa_vendedores.csv"`.')
            dataframe_or_warning(carregar_previa_vendedores_resumo(), "Sem resumo de prévia.")
            dataframe_periodo(carregar_base_previa_vendedores(), "Sem prévia de vendedores.", data_inicio_prev, data_fim_prev)

        st.markdown("### Índices no final da página")
        dataframe_or_warning(carregar_indices_setoriais_atuais(uf="MG"), "Índices setoriais ainda não calculados.")

        st.markdown("### Exportar bases da Previsão de Mercado")
        excel = exportar_bases_previsao_mercado_excel(indicador=indicador, produtos=produtos_sel)
        st.download_button(
            "Baixar Excel — Previsão de Mercado",
