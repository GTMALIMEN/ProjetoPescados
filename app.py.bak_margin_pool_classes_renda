def _date_range_from_period(periodo: str):
    """Retorna intervalo de datas para filtros visuais."""
    from datetime import date, timedelta
    hoje = date.today()
    if periodo == "Últimos 3 meses":
        return hoje - timedelta(days=90), hoje
    if periodo == "Últimos 6 meses":
        return hoje - timedelta(days=180), hoje
    if periodo == "Últimos 12 meses":
        return hoje - timedelta(days=365), hoje
    if periodo == "Últimos 24 meses":
        return hoje - timedelta(days=730), hoje
    if periodo == "Ano atual":
        return date(hoje.year, 1, 1), hoje
    return None, None


def _filter_df_by_period(df: pd.DataFrame, data_inicio=None, data_fim=None, possible_cols=None) -> pd.DataFrame:
    """Filtra dataframe por período procurando colunas comuns de data."""
    if df is None or not isinstance(df, pd.DataFrame) or df.empty:
        return pd.DataFrame() if df is None else df

    possible_cols = possible_cols or [
        "data", "mes", "data_referencia", "data_venda", "data_compra",
        "data_execucao", "data_coleta", "ultima_data", "primeira_data"
    ]

    out = df.copy()
    date_col = None
    for col in possible_cols:
        if col in out.columns:
            date_col = col
            break

    if date_col is None:
        return out

    dt = pd.to_datetime(out[date_col], errors="coerce")
    mask = pd.Series(True, index=out.index)

    if data_inicio is not None:
        mask &= dt.dt.date >= data_inicio
    if data_fim is not None:
        mask &= dt.dt.date <= data_fim

    return out[mask].copy()


def _drop_duplicate_columns(df: pd.DataFrame) -> pd.DataFrame:
    """Remove colunas duplicadas ou sufixos de merge visual, sem alterar o banco."""
    if df is None or not isinstance(df, pd.DataFrame) or df.empty:
        return pd.DataFrame() if df is None else df

    out = df.copy()
    out = out.loc[:, ~out.columns.duplicated()]

    for suffix in ["_x", "_y"]:
        dup_cols = [c for c in out.columns if c.endswith(suffix)]
        for col in dup_cols:
            base = col[:-2]
            if base in out.columns:
                out = out.drop(columns=[col])
    return out




